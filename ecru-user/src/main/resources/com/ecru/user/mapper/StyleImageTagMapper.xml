<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ecru.user.mapper.StyleImageTagMapper">

    <select id="selectByImageId" resultType="com.ecru.user.entity.StyleImageTag">
        SELECT * FROM style_image_tag WHERE image_id = #{imageId}
    </select>

    <select id="selectByStyleTagId" resultType="com.ecru.user.entity.StyleImageTag">
        SELECT * FROM style_image_tag WHERE style_tag_id = #{styleTagId}
    </select>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO style_image_tag (image_id, style_tag_id, created_at)
        VALUES
        <foreach collection="tags" item="tag" separator=",">
            (#{tag.imageId}, #{tag.styleTagId}, #{tag.createdAt})
        </foreach>
    </insert>

</mapper>